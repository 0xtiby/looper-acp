{
  "name": "@0xtiby/looper-acp",
  "version": "0.0.0-development",
  "description": "ACP-native Ralph Loop engine — stateless agent iteration via the Agent Client Protocol",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "looper-acp": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --bail 1",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "keywords": [
    "ai",
    "cli",
    "loop",
    "orchestration",
    "acp",
    "agent-client-protocol",
    "ralph-loop"
  ],
  "author": "0xtiby",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xtiby/looper-acp.git"
  },
  "bugs": {
    "url": "https://github.com/0xtiby/looper-acp/issues"
  },
  "homepage": "https://github.com/0xtiby/looper-acp#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.22.1",
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.1",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.1.3"
}
